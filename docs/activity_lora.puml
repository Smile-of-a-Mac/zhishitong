@startuml LoRA微调管线活动图
' ============================================================
' 智审通 — LoRA 微调管线活动图
' ============================================================

skinparam backgroundColor #FEFEFE
skinparam defaultFontSize 12
skinparam shadowing true
skinparam activityDiamondBackgroundColor #FFF9C4

title LoRA 微调管线活动图

|数据准备|
start
:爬取山科大教务处/研究生院页面;
note right
  jwc.sdust.edu.cn (工作流程/通知公告)
  yjsy.sdust.edu.cn (工作部/规章制度)
end note
:HTML 解析 → 提取文本;
:生成 instruction/input/output 三元组;
:输出 sdust_process_corpus_lora.jsonl;
note right: 约 9 条高质量训练样本

|LoRA 训练|
:加载本地 Qwen2.5-0.5B 基座模型;
note right
  BASE_MODEL_DIR = models/qwen2.5-0.5b-local/
  从 GGUF 文件加载
end note
:配置 LoRA 参数;
note right
  r=16, alpha=32, dropout=0.05
  targets: q/k/v/o_proj + gate/up/down_proj
end note
:50 epoch 训练;
note right
  batch=1, grad_accum=8 (等效8)
  lr=2e-4, max_seq=1024
  设备: Apple MPS / CUDA / CPU
end note
:保存 checkpoint-50/ checkpoint-100/ final/;
note right: adapter_config.json + adapter_model.safetensors

|合并 & 转换|
:加载 LoRA adapter (final/);
:merge_and_unload() 合并到基座模型;
:保存 lora_output_merged/ (HF 格式);
note right: model.safetensors ≈ 1GB
:convert_hf_to_gguf → q8_0 量化;
:输出 models/qwen2.5-0.5b-lora.gguf;
note right: GGUF 格式，llama.cpp 直接加载

|推理部署|
:启动 start.sh;
if (检测到 lora_output_merged/?) then (是)
  if (GGUF 已存在?) then (是)
    :跳过转换;
  else (否)
    :自动执行 convert_hf_to_gguf;
  endif
  :export MODEL_PATH=微调模型路径;
else (否)
  :使用原始模型;
endif
:启动 llama.cpp 推理服务;
:Qwen2.5-0.5B-LoRA 常驻内存;
stop

@enduml
