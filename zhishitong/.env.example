# ===== 智审通 环境变量示例 =====
# 复制为 .env 后修改

# LLM API（阿里百炼示例，替换你自己的 Key）
LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=qwen-vl-plus

# JWT 密钥（生产环境务必修改为随机字符串）
JWT_SECRET=change-this-to-a-random-string

# Fernet 加密密钥（部署时生成: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"）
ENCRYPTION_KEY=
