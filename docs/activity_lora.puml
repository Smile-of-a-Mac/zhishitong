@startuml LoRA微调管线活动图
' ============================================================
' 智审通 — LoRA 微调管线活动图（v0.6.3）
' ============================================================

skinparam backgroundColor #FEFEFE
skinparam defaultFontSize 12
skinparam shadowing true
skinparam activityDiamondBackgroundColor #FFF9C4

title LoRA 微调管线活动图（MLX 主线 + PEFT 备选）

|数据准备|
start
:生成分类语料 sdust_classification.jsonl;
:生成多任务语料 sdust_multitask_lora.jsonl;
note right
  分类：10 类事务识别
  多任务：document_type + prefill_fields + ambiguity
end note

|训练路线选择|
if (Apple Silicon / MLX 可用?) then (是)
  |MLX 14B 主线|
  :加载 models/Qwen3-14B;
  :training/train_lora_mlx.py;
  :训练 LoRA adapter;
  :mlx_lm fuse --dequantize;
  :convert_hf_to_gguf.py;
  :输出 models/qwen3-14b-lora.gguf;
else (否)
  |PEFT 跨平台备选|
  :加载 models/Qwen3-4B;
  :training/train_lora.py;
  :training/merge_lora.py;
  :输出 4B GGUF 备选模型;
endif

|推理部署|
:启动 zhishitong/start.sh;
if (检测到 models/qwen3-14b-lora.gguf?) then (是)
  :export MODEL_PATH=models/qwen3-14b-lora.gguf;
else (否)
  :使用 MODEL_PATH 指定模型或 4B 备选;
endif
:启动 llama.cpp 推理服务 (:18080);
:本地 RAG/合规分析兜底常驻;
stop

@enduml
